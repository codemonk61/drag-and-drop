# Backend API base URL
# When set, the builder will:
#   - Upload images to your server (POST /api/upload) instead of storing base64
#   - Auto-save layouts to your backend (POST /api/storefront)
#   - Enable publish flow (PUT /api/storefront/publish)
#
# When NOT set, the builder runs in demo/local mode:
#   - Images are stored as compressed base64 in the layout JSON
#   - Layouts are saved to localStorage only
#   - Export/Import via JSON files still works

# VITE_API_BASE_URL=https://api.trafasa.com/api
# VITE_API_BASE_URL=http://localhost:8000/api
